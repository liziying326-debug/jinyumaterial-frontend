<!-- ── FOOTER (same as other pages) ──────────────────────────────────── -->
<script>
// ── Product Detail 页 FAQ + 询盘表单 ──────────────────────────────────────
(function() {
  // FAQ Tab 切换
  const tabMap = { products: 'products-faq-pd', ordering: 'ordering-faq-pd', shipping: 'shipping-faq-pd', quality: 'quality-faq-pd' };
  const faqSection = document.getElementById('quote-faq');
  if (!faqSection) return;
  const tabs = faqSection.querySelectorAll('.faq-tab');
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      const key = btn.dataset.tab;
      Object.values(tabMap).forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('show');
      });
      const target = document.getElementById(tabMap[key]);
      if (target) target.classList.add('show');
    });
  });

  // FAQ accordion
  faqSection.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.closest('.faq-item');
      const ans  = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('expanded');
      const block = q.closest('.faq-content');
      block.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('expanded');
        i.querySelector('.faq-answer').classList.remove('show');
      });
      if (!isOpen) { item.classList.add('expanded'); ans.classList.add('show'); }
    });
  });

  // 询盘表单提交
  const qForm = document.getElementById('pdQuoteForm');
  if (qForm) {
    qForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const name    = document.getElementById('pd-name').value.trim();
      const email   = document.getElementById('pd-email').value.trim();
      const phone   = document.getElementById('pd-phone').value.trim();
      const message = document.getElementById('pd-message').value.trim();
      if (!name || !email || !message) { alert('Please fill in all required fields (*)'); return; }
      const btn = this.querySelector('button[type="submit"]');
      const origText = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.innerHTML = '⏳ Sending...'; }
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, message, source: 'product-detail-' + (productSlug || id || 'unknown') })
        });
        const data = await res.json();
        if (data.success) { showSuccessModal(); this.reset(); }
        else { alert('Submit failed: ' + (data.message || 'Unknown error')); }
      } catch(err) {
        showSuccessModal();
        this.reset();
      } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = origText; }
      }
    });
  }
})();
</script>

<!-- SUCCESS MODAL -->
<div class="success-modal-overlay" id="successModal" onclick="closeSuccessModal(event)">
  <div class="success-modal">
    <div class="success-modal-icon">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    <h3 data-i18n="successModal.title">Inquiry Received!</h3>
    <p data-i18n="successModal.message">Thanks for Your Inquiry, We will Get back to You within 8 Working Hours!</p>
    <button class="success-close-btn" onclick="closeSuccessModal()" data-i18n="successModal.close">Got It</button>
  </div>
</div>
<script>
function showSuccessModal() {
  var o = document.getElementById('successModal');
  if (o) { o.classList.add('show'); document.body.style.overflow='hidden'; }
}
function closeSuccessModal(e) {
  if (e && e.target !== document.getElementById('successModal') && !e.target.classList.contains('success-close-btn')) return;
  var o = document.getElementById('successModal');
  if (o) { o.classList.remove('show'); document.body.style.overflow=''; }
}
document.addEventListener('keydown', function(e) {
  if (e.key==='Escape') closeSuccessModal({target:document.getElementById('successModal')});
});
</script>

