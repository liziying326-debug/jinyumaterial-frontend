          <div class="dropdown" id="nav-product-dropdown"></div>
        </li>
        <li class="nav-item">
          <a href="applications.html" class="nav-link" data-i18n="nav.applications">Applications <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          <div class="dropdown">
            <a href="applications.html#sign-board" data-i18n="nav.applications_sub.signBoard">Sign Board</a>
            <a href="applications.html#light-box" data-i18n="nav.applications_sub.lightBox">Light Box</a>
            <a href="applications.html#digital-printing" data-i18n="nav.applications_sub.digitalPrinting">Digital Printing</a>
            <a href="applications.html#outdoor-advertising" data-i18n="nav.applications_sub.outdoorAdvertising">Outdoor Advertising</a>
            <a href="applications.html#exhibition-display" data-i18n="nav.applications_sub.exhibitionDisplay">Exhibition Display</a>
          </div>
        </li>
        <li class="nav-item"><a href="case-studies.html" class="nav-link" data-i18n="nav.caseStudies">Cases / Videos</a></li>
        <li class="nav-item">
          <a href="news.html" class="nav-link" data-i18n="nav.news">News <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          <div class="dropdown">
            <a href="news.html#industry-knowledge" data-i18n="nav.blog_sub.industryKnowledge">Industry Knowledge</a>
            <a href="news.html#material-guide" data-i18n="nav.blog_sub.materialGuide">Material Guide</a>
            <a href="news.html#printing-technology" data-i18n="nav.blog_sub.printingTechnology">Printing Technology</a>
          </div>
        </li>
        <li class="nav-item">
          <a href="about.html" class="nav-link" data-i18n="nav.aboutUs">About Us <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
          <div class="dropdown">
            <a href="about.html#company-profile" data-i18n="nav.about_sub.companyProfile">Company Profile</a>
            <a href="about.html#factory" data-i18n="nav.about_sub.factory">Factory</a>
            <a href="about.html#production-capacity" data-i18n="nav.about_sub.productionCapacity">Production Capacity</a>
            <a href="about.html#certificates" data-i18n="nav.about_sub.certificates">Certificates</a>
          </div>
        </li>
        <li class="nav-item"><a href="contact.html" class="nav-link" data-i18n="nav.contactUs">Contact Us</a></li>
      </ul>
      <div class="nav-right">
        <div class="nav-social">
          <a href="https://facebook.com" target="_blank" rel="noopener" class="nav-social-icon facebook" title="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
          </a>
          <a href="https://tiktok.com" target="_blank" rel="noopener" class="nav-social-icon tiktok" title="TikTok">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.67a8.2 8.2 0 004.79 1.53V6.75a4.85 4.85 0 01-1.02-.06z"/></svg>
          </a>
          <a href="https://wa.me/8613808828019" target="_blank" rel="noopener" class="nav-social-icon whatsapp" title="WhatsApp">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
        <div class="nav-divider"></div>
        <div class="nav-lang" id="language-switcher">
          <div class="lang-display">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            <span class="lang-code">EN</span>
          </div>
        </div>
        <div class="nav-divider"></div>
        <a href="contact.html" class="btn btn-primary btn-sm nav-cta" data-i18n="nav.getQuote">Get a Quote</a>
      </div>
      <div class="nav-hamburger" id="hamburger" onclick="toggleMenu()"><span></span><span></span><span></span></div>
    </div>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="pd-breadcrumb-bar">
  <div class="container">
    <a href="index.html" data-i18n="nav.home">Home</a>
    <span class="sep">›</span>
    <a href="products.html" data-i18n="nav.products">Products</a>
    <span class="sep">›</span>
    <span class="current" id="pdBannerName">Product Detail</span>
  </div>
</div>

<!-- ── MAIN CONTENT ───────────────────────────────────────────────────── -->
<main class="container" style="padding-top:32px; padding-bottom:80px;">

  <!-- Product Detail Body -->
  <div id="pdBody" style="display:none;">
    <div class="pd-hero">
      <!-- Left: Image Gallery -->
      <div class="pd-gallery">
        <img id="pdMainImg" class="pd-main-img" src="" alt="">
        <div class="pd-thumbs" id="pdThumbs"></div>
      </div>

      <!-- Right: Info -->
      <div class="pd-info">
        <div class="pd-category" id="pdCategory"></div>
        <h1 class="pd-name" id="pdName"></h1>
        <p class="pd-desc" id="pdDesc"></p>

        <div class="pd-specs" id="pdSpecsBox">
          <h4 data-i18n="productDetail.specifications">Specifications</h4>
          <table class="pd-spec-table" id="pdSpecTable"></table>
        </div>

        <div class="pd-features" id="pdFeaturesBox">
          <h4 data-i18n="productDetail.keyFeatures">Product Features</h4>
          <ul class="pd-feature-list" id="pdFeatureList"></ul>
        </div>

        <div class="pd-actions">
          <a href="contact.html" class="pd-btn-quote">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span data-i18n="productDetail.getQuote">Get a Quote</span>
          </a>

        </div>
      </div>
    </div>

    <!-- Related Products -->
    <div class="pd-related">
      <h3 data-i18n="productDetail.relatedProducts">Related Products</h3>
      <div class="pd-related-grid" id="pdRelatedGrid"></div>
    </div>
  </div>

  <!-- Not Found -->
  <div id="pdNotFound" style="display:none;" class="pd-notfound">
    <h2 data-i18n="productDetail.notFound">Product Not Found</h2>
    <p data-i18n="productDetail.notFoundDesc">The product you're looking for doesn't exist or has been removed.</p>
    <a href="products.html" class="pd-btn-back" data-i18n="productDetail.backToProducts">Back to Products</a>
  </div>

</main>

<!-- CTA BANNER -->
<section class="section cta-banner">
  <div class="container">
    <div class="cta-content">
      <div class="cta-text">
        <h2 data-i18n="cta.title">Ready to Source Premium Advertising Materials?</h2>
        <p data-i18n="cta.subtitle">Contact our team today for product specifications, pricing, and export shipping details. We respond within 24 hours on business days.</p>
      </div>
      <div class="cta-actions">
        <a href="contact.html" class="btn btn-primary btn-lg" data-i18n="cta.getQuote">Get a Quote</a>
        <a href="https://wa.me/8613808828019" target="_blank" class="btn btn-outline btn-lg" data-i18n="cta.whatsapp">💬 WhatsApp Us</a>
      </div>
    </div>
  </div>
</section>

<!-- QUOTE & FAQ -->
<section class="section bg-light" id="quote-faq">
  <div class="container">
    <div class="grid-2">
      <!-- Left: Quote Form -->
      <div class="quote-form-box">
        <h2 class="quote-title" data-i18n="quoteForm.title">Send Us Your Project Details</h2>
        <p class="quote-subtitle" data-i18n="quoteForm.subtitle">Get a Quote Within 24 Hours</p>
        <form class="quote-form" id="pdQuoteForm">
          <div class="form-group">
            <label for="pd-name" data-i18n="quoteForm.name">Name *</label>
            <input type="text" id="pd-name" class="form-input" data-i18n-placeholder="quoteForm.namePlaceholder" placeholder="Your Name" required>
          </div>
          <div class="form-group">
            <label for="pd-email" data-i18n="quoteForm.email">Email *</label>
            <input type="email" id="pd-email" class="form-input" data-i18n-placeholder="quoteForm.emailPlaceholder" placeholder="your@email.com" required>
          </div>
          <div class="form-group">
            <label for="pd-phone" data-i18n="quoteForm.phone">Phone *</label>
            <input type="tel" id="pd-phone" class="form-input" data-i18n-placeholder="quoteForm.phonePlaceholder" placeholder="+86 xxx xxxx xxxx">
          </div>
          <div class="form-group">
            <label for="pd-message" data-i18n="quoteForm.message">Message *</label>
            <textarea id="pd-message" class="form-textarea" rows="4" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;" data-i18n="quoteForm.submit">Submit</button>
        </form>
      </div>

      <!-- Right: FAQ -->
      <div class="faq-box">
        <div class="faq-header">
          <span class="faq-icon">❓</span>
          <h2 class="faq-title" data-i18n="faq.title">We're Here to Answer All Your Questions</h2>
        </div>
        <div class="faq-tabs">
          <button class="faq-tab active" data-tab="products" data-i18n="faq.tab_products">Products</button>
          <button class="faq-tab" data-tab="ordering" data-i18n="faq.tab_ordering">Ordering & Payment</button>
          <button class="faq-tab" data-tab="shipping" data-i18n="faq.tab_shipping">Shipping & Delivery</button>
          <button class="faq-tab" data-tab="quality" data-i18n="faq.tab_quality">Quality & Certification</button>
        </div>
        <div class="faq-content show" id="products-faq-pd">
          <div class="faq-item expanded">
            <div class="faq-question"><span data-i18n="faq.q1_1">What are your main products?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
            <div class="faq-answer show" data-i18n="faq.a1_1">We specialize in Self Adhesive Vinyl, PVC Flex Banner, Cutting Plotter Film, Acrylic Sheet, PVC Foam Board, and Display Equipment.</div>
          </div>
          <div class="faq-item">
            <div class="faq-question"><span data-i18n="faq.q1_2">Do you offer custom sizes and specifications?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
            <div class="faq-answer" data-i18n="faq.a1_2">Yes, we offer custom sizes, thickness, and specifications. Please provide your detailed requirements.</div>
          </div>
          <div class="faq-item">
            <div class="faq-question"><span data-i18n="faq.q1_3">What is your minimum order quantity (MOQ)?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
            <div class="faq-answer" data-i18n="faq.a1_3">Our MOQ varies by product type. Generally it's 100 pieces for standard products.</div>
          </div>
        </div>
        <div class="faq-content" id="ordering-faq-pd">
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q2_1">What payment methods do you accept?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a2_1">We accept T/T, PayPal, and Western Union. New customers may require a 30% deposit.</div></div>
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q2_2">How long does it take to process my order?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a2_2">Standard products ship within 3-7 days. Custom orders may take 10-15 days.</div></div>
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q2_3">Can I request samples before placing a bulk order?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a2_3">Yes, we offer free samples for standard products. Customers only need to cover shipping cost.</div></div>
        </div>
        <div class="faq-content" id="shipping-faq-pd">
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q3_1">Do you ship internationally?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a3_1">Yes, we ship to over 50 countries worldwide via DHL, FedEx, UPS, and sea freight.</div></div>
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q3_2">What are the shipping costs?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a3_2">Costs depend on destination, weight, and method. We will quote exact shipping cost on order.</div></div>
          <div class="faq-item"><div class="faq-question"><span data-i18n="faq.q3_3">How long does delivery take?</span><svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div><div class="faq-answer" data-i18n="faq.a3_3">Express shipping takes 5-7 business days. Sea freight takes 25-35 days.</div></div>
        </div>
        <div class="faq-content" id="quality-faq-pd">
