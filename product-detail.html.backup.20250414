<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Product Detail – Jinyu</title>
<link rel="stylesheet" href="/styles.css">
<style>
/* ── Detail Page Specific ─────────────────────────────── */
.pd-breadcrumb-bar {
  background: #fff;
  border-bottom: 1px solid #eee;
  padding: 12px 0;
  font-size: 13px;
  color: #888;
  margin-top: 70px; /* nav高度 */
}
.pd-breadcrumb-bar a { color: #555; text-decoration: none; }
.pd-breadcrumb-bar a:hover { color: #e87722; }
.pd-breadcrumb-bar .sep { margin: 0 6px; color: #bbb; }
.pd-breadcrumb-bar .current { color: #e87722; font-weight: 500; }

.pd-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; padding: 40px 0 60px; }
@media(max-width:768px){ .pd-hero { grid-template-columns:1fr; gap:28px; } }

.pd-gallery { position: sticky; top: 88px; }
.pd-main-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 12px; background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%); min-height: 200px; }
.pd-thumbs { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
.pd-thumb { width: 72px; height: 72px; object-fit: cover; border-radius: 8px; cursor: pointer;
            border: 2px solid transparent; transition: border-color .2s; }
.pd-thumb:hover, .pd-thumb.active { border-color: #e87722; }

.pd-info {}
.pd-category { font-size: 12px; font-weight: 600; color: #e87722; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 8px; }
.pd-name { font-size: 32px; font-weight: 700; color: #1a1a2e; line-height: 1.2; margin-bottom: 16px; }
.pd-desc { font-size: 15px; color: #555; line-height: 1.7; margin-bottom: 28px; }

.pd-specs { background: #f9f9fb; border-radius: 12px; padding: 24px; margin-bottom: 28px; }
.pd-specs h4 { font-size: 14px; font-weight: 700; color: #333; margin-bottom: 16px; text-transform: uppercase; letter-spacing: .05em; }
.pd-spec-table { width: 100%; border-collapse: collapse; }
.pd-spec-table tr { border-bottom: 1px solid #eee; }
.pd-spec-table tr:last-child { border-bottom: none; }
.pd-spec-table td { padding: 10px 8px; font-size: 14px; }
.pd-spec-table td:first-child { color: #888; width: 45%; }
.pd-spec-table td:last-child { color: #222; font-weight: 500; }

.pd-features { margin-bottom: 28px; }
.pd-features h4 { font-size: 14px; font-weight: 700; color: #333; margin-bottom: 12px; text-transform: uppercase; letter-spacing: .05em; }
.pd-feature-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.pd-feature-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #444; }
.pd-feature-list li::before { content: "✓"; color: #e87722; font-weight: 700; flex-shrink: 0; margin-top: 1px; }

.pd-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.pd-btn-quote { display: inline-flex; align-items: center; gap: 8px; background: #e87722; color: #fff;
                padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600;
                text-decoration: none; transition: background .2s; }
.pd-btn-quote:hover { background: #d4621a; }
.pd-btn-back { display: inline-flex; align-items: center; gap: 8px; background: #fff; color: #333;
               padding: 14px 24px; border-radius: 8px; font-size: 15px; font-weight: 500;
               text-decoration: none; border: 2px solid #ddd; transition: border-color .2s; }
.pd-btn-back:hover { border-color: #e87722; color: #e87722; }

/* Related Products */
.pd-related { padding: 60px 0; border-top: 1px solid #eee; }
.pd-related h3 { font-size: 22px; font-weight: 700; margin-bottom: 28px; color: #1a1a2e; }
.pd-related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
.pd-rel-card { border-radius: 10px; overflow: hidden; border: 1px solid #eee; cursor: pointer;
               transition: box-shadow .2s, transform .2s; background: #fff; }
.pd-rel-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.1); transform: translateY(-3px); }
.pd-rel-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
.pd-rel-card-name { padding: 12px 14px; font-size: 13px; font-weight: 600; color: #333; }

/* Not found state */
.pd-notfound { text-align: center; padding: 120px 20px; }
.pd-notfound h2 { font-size: 24px; color: #333; margin-bottom: 12px; }
.pd-notfound p { color: #888; margin-bottom: 28px; }
</style>
</head>
<body>

<!-- NAV -->
<nav class="navbar" id="navbar">
  <div class="container">
    <div class="nav-inner">
      <a href="index.html" class="nav-logo">
        <div class="logo-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 28V12L20 8L32 12V28L20 32L8 28Z" stroke="#E8751A" stroke-width="2.5" fill="none"/>
            <path d="M8 12L20 16L32 12" stroke="#E8751A" stroke-width="2.5"/>
            <path d="M20 16V32" stroke="#E8751A" stroke-width="2.5"/>
            <circle cx="20" cy="24" r="3" fill="#E8751A"/>
            <text x="20" y="23" text-anchor="middle" fill="white" font-size="10" font-weight="800" font-family="Montserrat">JY</text>
          </svg>
        </div>
        <div class="logo-text">
          <div class="logo-name">Jin Yu</div>
          <div class="logo-sub">Advertising Material</div>
        </div>
      </a>
      <ul class="nav-menu" id="navMenu">
        <li class="nav-item"><a href="index.html" class="nav-link" data-i18n="nav.home">Home</a></li>
        <li class="nav-item">
