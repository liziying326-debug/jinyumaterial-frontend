<!-- ========== QUOTE & FAQ ========== -->
<section class="section bg-light" id="quote-faq">
  <div class="container">
    <div class="grid-2">
      <!-- Left: Quote Form -->
      <div class="quote-form-box">
        <h2 class="quote-title" data-i18n="quoteForm.title">Send Us Your Project Details</h2>
        <p class="quote-subtitle" data-i18n="quoteForm.subtitle">Get a Quote Within 24 Hours</p>
        <form class="quote-form">
          <div class="form-group">
            <label for="quote-name" data-i18n="quoteForm.name">Name *</label>
            <input type="text" id="quote-name" class="form-input" data-i18n-placeholder="quoteForm.namePlaceholder" placeholder="Your Name" required>
          </div>
          <div class="form-group">
            <label for="quote-email" data-i18n="quoteForm.email">Email *</label>
            <input type="email" id="quote-email" class="form-input" data-i18n-placeholder="quoteForm.emailPlaceholder" placeholder="your@email.com" required>
          </div>
          <div class="form-group">
            <label for="quote-phone" data-i18n="quoteForm.phone">Phone *</label>
            <input type="tel" id="quote-phone" class="form-input" data-i18n-placeholder="quoteForm.phonePlaceholder" placeholder="+86 xxx xxxx xxxx" required>
          </div>
          <div class="form-group">
            <label for="quote-message" data-i18n="quoteForm.message">Message *</label>
            <textarea id="quote-message" class="form-textarea" data-i18n-placeholder="quoteForm.messagePlaceholder" placeholder="Tell us about your project..." rows="4" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; justify-content: center;" data-i18n="quoteForm.submit">Submit</button>
        </form>
      </div>

      <!-- Right: FAQ -->
      <div class="faq-box">
        <div class="faq-header">
          <span class="faq-icon">❓</span>
          <h2 class="faq-title" data-i18n="faq.title">We're Here to Answer All Your Questions</h2>
        </div>
        <div class="faq-tabs">
          <button class="faq-tab active" data-tab="products" data-i18n="faq.tab_products">Products</button>
          <button class="faq-tab" data-tab="ordering" data-i18n="faq.tab_ordering">Ordering & Payment</button>
          <button class="faq-tab" data-tab="shipping" data-i18n="faq.tab_shipping">Shipping & Delivery</button>
          <button class="faq-tab" data-tab="quality" data-i18n="faq.tab_quality">Quality & Certification</button>
        </div>
        <div class="faq-content show" id="products-faq-p">
          <div class="faq-item expanded">
            <div class="faq-question">
              <span data-i18n="faq.q1_1">What are your main products?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer show" data-i18n="faq.a1_1">
              We specialize in Self Adhesive Vinyl, PVC Flex Banner, Cutting Plotter Film, Acrylic Sheet, PVC Foam Board, and Display Equipment. We also offer custom specifications according to your requirements.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q1_2">Do you offer custom sizes and specifications?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a1_2">
              Yes, we offer custom sizes, thickness, and specifications. Please provide your detailed requirements, and our team will provide a solution tailored to your needs.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q1_3">What is your minimum order quantity (MOQ)?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a1_3">
              Our MOQ varies by product type. Generally, it's 100 pieces for standard products. For custom orders, please contact us directly for specific requirements.
            </div>
          </div>
        </div>
        <div class="faq-content" id="ordering-faq-p">
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q2_1">What payment methods do you accept?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a2_1">
              We accept T/T (Wire Transfer), PayPal, and Western Union. For new customers, we may require a 30% deposit with the balance paid before shipment.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q2_2">How long does it take to process my order?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a2_2">
              Production time varies by product. Standard products ship within 3-7 days. Custom orders may take 10-15 days. We'll provide an estimated delivery date upon order confirmation.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q2_3">Can I request samples before placing a bulk order?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a2_3">
              Yes, we offer free samples for standard products. Customers only need to cover the shipping cost. For custom samples, please contact us for pricing.
            </div>
          </div>
        </div>
        <div class="faq-content" id="shipping-faq-p">
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q3_1">Do you ship internationally?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a3_1">
              Yes, we ship to over 50 countries worldwide. We work with major shipping carriers like DHL, FedEx, UPS, and sea freight for larger orders.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q3_2">What are the shipping costs?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a3_2">
              Shipping costs depend on destination, weight, and shipping method. We provide competitive rates and will quote you the exact shipping cost when you place your order.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q3_3">How long does delivery take?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a3_3">
              Express shipping (DHL/FedEx/UPS) takes 5-7 business days. Sea freight takes 25-35 days depending on the destination country and port.
            </div>
          </div>
        </div>
        <div class="faq-content" id="quality-faq-p">
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q4_1">Are your products certified?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a4_1">
              Yes, we are ISO 9001:2015 certified. Our products meet international quality standards and are exported to Europe, Americas, Southeast Asia, and Middle East markets.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q4_2">Do you offer quality guarantees?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a4_2">
              Absolutely! We offer a 100% quality guarantee. If you receive defective products, we will replace them free of charge or provide a full refund.
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">
              <span data-i18n="faq.q4_3">Can you provide test reports or samples?</span>
              
              <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="faq-answer" data-i18n="faq.a4_3">
              Yes, we can provide test reports, certificates, and samples upon request. Our quality control team conducts thorough inspections before shipment.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

