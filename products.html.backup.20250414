<script>
window.addEventListener('scroll', () => {
  const nb = document.getElementById('navbar');
  if (window.scrollY > 60) nb.classList.add('scrolled');
  else nb.classList.remove('scrolled');
  // Sticky tab bar shadow
  const tb = document.getElementById('pcatTabsBar');
  if (tb) tb.classList.toggle('scrolled', window.scrollY > 120);
});

function toggleMenu() {
  document.getElementById('navMenu').classList.toggle('open');
}

// ── Language helpers ──────────────────────────────────────────────────────
function applyBilingualAttr(lang) {
  document.querySelectorAll('[data-i18n-en]').forEach(el => {
    if (lang === 'zh') el.textContent = el.dataset.i18nZh || el.dataset.i18nEn;
    else if (lang === 'vi') el.textContent = el.dataset.i18nVi || el.dataset.i18nEn;
    else if (lang === 'tl') el.textContent = el.dataset.i18nTl || el.dataset.i18nEn;
    else el.textContent = el.dataset.i18nEn;
  });
}
document.addEventListener('langChange', (e) => {
  const lang = e.detail?.lang || (window.i18n && i18n.currentLang) || 'en';
  applyBilingualAttr(lang);
  if (window.i18n) i18n.applyTranslations();
});

// ── Category Tab Switching ────────────────────────────────────────────────
function switchCat(cat) {
  document.querySelectorAll('.pcat-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.cat === cat);
  });
  document.querySelectorAll('.pcat-panel').forEach(p => {
    p.style.display = p.id === 'panel-' + cat ? '' : 'none';
  });
  // 切换后滚动到 Tab 栏顶部
  const anchor = document.getElementById('tabAnchor');
  if (anchor) {
    const navH = document.getElementById('navbar') ? document.getElementById('navbar').offsetHeight : 70;
    window.scrollTo({ top: anchor.offsetTop - navH, behavior: 'smooth' });
  }
}

// ── FAQ Tab Switching (Products Page) ────────────────────────────────────
(function initFaqP() {
  const tabMap = { products: 'products-faq-p', ordering: 'ordering-faq-p', shipping: 'shipping-faq-p', quality: 'quality-faq-p' };
  const faqSection = document.getElementById('quote-faq');
  if (!faqSection) return;
  const tabs = faqSection.querySelectorAll('.faq-tab');
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      const key = btn.dataset.tab;
      Object.values(tabMap).forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('show');
      });
      const target = document.getElementById(tabMap[key]);
      if (target) target.classList.add('show');
    });
  });

  // FAQ accordion
  faqSection.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.closest('.faq-item');
      const ans = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('expanded');
      // Close all in same content block
      const block = q.closest('.faq-content');
      block.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('expanded');
        i.querySelector('.faq-answer').classList.remove('show');
      });
      if (!isOpen) {
        item.classList.add('expanded');
        ans.classList.add('show');
      }
    });
  });

  // Quote Form Submission - 真实提交到后台
  const qForm = document.querySelector('.quote-form');
  if (qForm) {
    qForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const name = document.getElementById('quote-name').value.trim();
      const email = document.getElementById('quote-email').value.trim();
      const phone = document.getElementById('quote-phone').value.trim();
      const message = document.getElementById('quote-message').value.trim();
      if (!name || !email || !message) {
        alert('Please fill in all required fields (*)');
        return;
      }
      const btn = this.querySelector('button[type="submit"]');
      const origText = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.innerHTML = '⏳ Sending...'; }
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, message, source: 'products-quote-form' }),
        });
        const data = await res.json();
        if (data.success) {
          showSuccessModal();
          this.reset();
        } else {
          alert('Submit failed: ' + (data.message || 'Unknown error'));
        }
      } catch (err) {
        showSuccessModal();
        this.reset();
      } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = origText; }
      }
    });
  }
})();
</script>

