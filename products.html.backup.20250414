<!-- ===== SUCCESS MODAL ===== -->
<div class="success-modal-overlay" id="successModal" onclick="closeSuccessModal(event)">
  <div class="success-modal">
    <div class="success-modal-icon">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h3 data-i18n="successModal.title">Inquiry Received!</h3>
    <p data-i18n="successModal.message">Thanks for Your Inquiry, We will Get back to You within 8 Working Hours!</p>
    <button class="success-close-btn" onclick="closeSuccessModal()" data-i18n="successModal.close">Got It</button>
  </div>
</div>


<script>
// ── Success Modal ──────────────────────────────────────────────────────────────
function showSuccessModal() {
  var overlay = document.getElementById('successModal');
  if (overlay) {
    overlay.classList.add('show');
    document.body.style.overflow = 'hidden';
  }
}
function closeSuccessModal(e) {
  if (e && e.target !== document.getElementById('successModal') && !e.target.classList.contains('success-close-btn')) return;
  var overlay = document.getElementById('successModal');
  if (overlay) {
    overlay.classList.remove('show');
    document.body.style.overflow = '';
  }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeSuccessModal({target: document.getElementById('successModal')});
});
</script>


<script>
// ═══════════════════════════════════════════════════════════
//  Products Page – API-driven rendering (categories + products)
// ═══════════════════════════════════════════════════════════
(function() {
  // 分类图标（按 slug 匹配，匹配不到用默认图标）
  const CAT_ICONS = {
    'advertising-media':  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>',
    'advertising-panel':  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>',
    'display-stand':      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v13H3z"/><path d="M12 16v5M8 21h8"/></svg>',
    'accessory':          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3-3a1 1 0 000-1.4l-1.6-1.6a1 1 0 00-1.4 0l-3 3z"/><path d="M5 19L3 21M9.4 13.6L5 19"/><circle cx="10" cy="13" r="3"/></svg>',
    'accessory-tools':    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3-3a1 1 0 000-1.4l-1.6-1.6a1 1 0 00-1.4 0l-3 3z"/><path d="M5 19L3 21M9.4 13.6L5 19"/><circle cx="10" cy="13" r="3"/></svg>',
    '_default':           '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>'
  };

  let allProducts  = [];
  let allCategories = [];
  let currentCat   = '';

  function getLang() {
    try { return localStorage.getItem('jinyu_lang') || localStorage.getItem('lang') || 'en'; } catch(e) { return 'en'; }
  }

  // 从数据对象按当前语言取字段（同步 fallback）
  // 注意：对 zh 语言，如果 _zh 字段为空但有 _en 内容，返回空字符串让 pickLang 触发翻译
  function pickLangSync(d, key, lang) {
    if (!d) return '';
    lang = lang || getLang();
    var val;
    if (lang === 'zh') {
      val = (d[key + '_zh'] || '').trim();
      if (!val && (d[key + '_en'] || '').trim()) return ''; // 有英文但无中文，让 pickLang 翻译
      return val || (d[key] || '');
    }
    if (lang === 'vi') {
      val = (d[key + '_vi'] || '').trim();
      if (!val && (d[key + '_en'] || '').trim()) return '';
      return val || (d[key + '_en'] || '') || (d[key] || '');
    }
    if (lang === 'tl') {
      val = (d[key + '_tl'] || '').trim();
      if (!val && (d[key + '_en'] || '').trim()) return '';
      return val || (d[key + '_en'] || '') || (d[key] || '');
    }
    return (d[key + '_en'] || '') || (d[key] || '');
  }

  // 异步版：字段为空时调 autoTranslate
  async function pickLang(d, key, lang) {
    lang = lang || getLang();
    var v = pickLangSync(d, key, lang);
    if (v) return v;
    if (window.autoTranslate) {
      return await window.autoTranslate.pickLang(d, key, lang);
    }
    return '';
  }

  // 获取产品主图
  function getProductImage(p) {
    if (Array.isArray(p.images) && p.images.length > 0) {
      const idx = parseInt(p.main_image) || 0;
      return p.images[idx] || p.images[0];
    }
    return p.image || '';
  }

  // 产品名/slug 转 URL slug
  function toSlug(s) {
    return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  // 生成产品详情页新式 URL：/products/:catSlug/:productSlug
  function productUrl(p) {
    const catSlug = p.category_id || '_';
    const pSlug   = p.slug ? toSlug(p.slug) : toSlug(p.name_en || p.name || '');
    return pSlug ? '/products/' + catSlug + '/' + pSlug : '/product-detail.html?id=' + p.id;
  }

  // 渲染单个产品卡片（异步，支持自动翻译）
  async function renderCard(p, lang) {
    const name = await pickLang(p, 'name', lang).catch(() => p.name_en || p.name || p.id || '');
    const btn  = (window.i18n ? window.i18n.t('products.viewDetail') : 'View Details');
    const img  = getProductImage(p);
    const pUrl = productUrl(p);
    const imgHtml = img
      ? `<img src="${img}" alt="${name}" loading="lazy" onerror="this.style.opacity=0.3">`
      : `<div style="width:100%;height:100%;background:linear-gradient(135deg,#f0f0f0,#e8e8e8);display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;">No Image</div>`;
    return `
<div class="product-card-new" id="${p.id}" onclick="location.href='${pUrl}'">
  <div class="pcn-img">
    ${imgHtml}
    <div class="pcn-overlay">
      <a href="${pUrl}" class="pcn-btn pcn-detail-btn" onclick="event.stopPropagation()">${btn}</a>
    </div>
  </div>
  <div class="pcn-body">
    <h3 class="pcn-name">${name}</h3>
  </div>
</div>`;
  }

  // 渲染分类面板（异步）
  async function renderPanel(cat, products, lang) {
    const slug = cat.slug || cat.id;
    const catLabel = (await pickLang(cat, 'name', lang).catch(() => '')) || cat.name_en || slug;
    const catDesc  = (await pickLang(cat, 'description', lang).catch(() => '')) || cat.description_en || '';
    const catProducts = products.filter(p => p.category_id === slug);
    const cardResults = await Promise.all(catProducts.map(p => renderCard(p, lang).catch(e => { console.warn('renderCard error', p.id, e); return ''; })));
    const cards = cardResults.join('');
    const isActive = (slug === currentCat);
    return `
<div class="pcat-panel" id="panel-${slug}" ${isActive ? '' : 'style="display:none"'}>
  <div class="container" style="padding-top:48px;">
    <div class="pcat-section-header">
      <h2>${catLabel}</h2>
      <p>${catDesc}</p>
    </div>
    <div class="pcat-grid">${cards || '<p style="color:#aaa;padding:24px 0;">No products in this category.</p>'}</div>
  </div>
</div>`;
  }

  // 渲染分类 Tab 栏（异步）
  async function renderTabs(categories, products, lang) {
    const tabsList = document.getElementById('pcatTabsList');
    if (!tabsList) return;
    const tabHtmls = await Promise.all(categories.map(async cat => {
      const slug     = cat.slug || cat.id;
      const icon     = CAT_ICONS[slug] || CAT_ICONS['_default'];
      const label    = await pickLang(cat, 'name', lang) || cat.name_en || slug;
      const count    = products.filter(p => p.category_id === slug).length;
      const isActive = slug === currentCat;
      return `<button class="pcat-tab${isActive?' active':''}" data-cat="${slug}" onclick="switchCat('${slug}')">
  <span class="pcat-icon">${icon}</span>
  <span class="pcat-label">${label}</span>
  <span class="pcat-count" data-cat-count>${count}</span>
</button>`;
    }));
    tabsList.innerHTML = tabHtmls.join('');
  }

  // 更新 Tab 上的数量徽章
  function updateCounts(products) {
    document.querySelectorAll('.pcat-tab').forEach(btn => {
      const cat   = btn.getAttribute('data-cat');
      const count = products.filter(p => p.category_id === cat).length;
      const badge = btn.querySelector('[data-cat-count]');
      if (badge) badge.textContent = count;
    });
  }

  // 主渲染
  async function renderAll(products, categories) {
    const lang = getLang();
    const container = document.getElementById('pcatContent');
    if (!container) return;
    try {
      // ── Step 1：同步生成 Tabs（用 fallback 文字，不等翻译）─────────
      const tabsList = document.getElementById('pcatTabsList');
      if (tabsList) {
        tabsList.innerHTML = categories.map(cat => {
          const slug  = cat.slug || cat.id;
          const icon  = CAT_ICONS[slug] || CAT_ICONS['_default'];
          const label = pickLangSync(cat, 'name', lang) || cat.name_en || cat.name || slug;
          const count = products.filter(p => p.category_id === slug).length;
          const isActive = slug === currentCat;
          return `<button class="pcat-tab${isActive?' active':''}" data-cat="${slug}" onclick="switchCat('${slug}')">
  <span class="pcat-icon">${icon}</span>
  <span class="pcat-label">${label}</span>
  <span class="pcat-count" data-cat-count>${count}</span>
</button>`;
        }).join('');
      }

      // ── Step 2：同步生成所有产品面板（用 fallback 文字）──────────
      const panelHtmls = categories.map(cat => {
        const slug       = cat.slug || cat.id;
        const catLabel   = pickLangSync(cat, 'name', lang) || cat.name_en || cat.name || slug;
        const catDesc    = pickLangSync(cat, 'description', lang) || cat.description_en || '';
        const catProducts = products.filter(p => p.category_id === slug);
        const isActive   = slug === currentCat;

        const cards = catProducts.map(p => {
          const name  = pickLangSync(p, 'name', lang) || p.name_en || p.name || '';
          const btn   = (window.i18n ? window.i18n.t('products.viewDetail') : 'View Details');
          const img   = getProductImage(p);
          const pUrl  = productUrl(p);
          const imgHtml = img
            ? `<img src="${img}" alt="${name}" loading="lazy" onerror="this.style.opacity=0.3">`
            : `<div style="width:100%;height:100%;background:linear-gradient(135deg,#f0f0f0,#e8e8e8);display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;">No Image</div>`;
          return `<div class="product-card-new" id="${p.id}" onclick="location.href='${pUrl}'">
  <div class="pcn-img">${imgHtml}<div class="pcn-overlay"><a href="${pUrl}" class="pcn-btn pcn-detail-btn" onclick="event.stopPropagation()">${btn}</a></div></div>
  <div class="pcn-body"><h3 class="pcn-name">${name}</h3></div>
</div>`;
        }).join('');

        return `<div class="pcat-panel" id="panel-${slug}" ${isActive ? '' : 'style="display:none"'}>
  <div class="container" style="padding-top:48px;">
    <div class="pcat-section-header"><h2>${catLabel}</h2><p>${catDesc}</p></div>
    <div class="pcat-grid">${cards || '<p style="color:#aaa;padding:24px 0;">No products in this category.</p>'}</div>
  </div>
</div>`;
      });
      container.innerHTML = panelHtmls.join('');
      if (window.applyI18n) window.applyI18n();

      // ── Step 3：确保当前分类的 tab/panel 处于激活状态 ─────────────
      if (currentCat) {
        document.querySelectorAll('.pcat-tab').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-cat') === currentCat);
        });
        document.querySelectorAll('.pcat-panel').forEach(el => {
          el.style.display = (el.id === 'panel-' + currentCat) ? '' : 'none';
        });
      }

    } catch(e) {
      console.error('renderAll error:', e);
    }
  }

  // 加载所有数据
  async function loadAll() {
    try {
      const [prodResp, catResp] = await Promise.all([
        fetch('/api/products'),
        fetch('/api/categories')
      ]);
      const prodJson = await prodResp.json();
      const catJson  = await catResp.json();

      // 兼容多种API格式: 数组 或 {success: true, data: [...]} 或 {value: [...], Count: N}
      allProducts   = Array.isArray(prodJson) ? prodJson : (prodJson.success ? prodJson.data : (prodJson.value || []));
      allCategories = Array.isArray(catJson) ? catJson : (catJson.success ? catJson.data : (catJson.value || []));

      // 按 sort_order 排序
      allCategories.sort((a, b) => (parseInt(a.sort_order)||0) - (parseInt(b.sort_order)||0));

      // 确定初始分类
      if (!currentCat && allCategories.length > 0) {
        currentCat = allCategories[0].slug || allCategories[0].id;
      }

      renderAll(allProducts, allCategories);

      // 隐藏 loading
      const loading = document.getElementById('pcatLoading');
      if (loading) loading.style.display = 'none';

    } catch(e) {
      const el = document.getElementById('pcatLoading');
      if (el) el.innerHTML = '<p style="color:#f87171;">Failed to load products. Please refresh.</p>';
    }
  }

  // 语言切换时重新渲染
  window.addEventListener('storage', function(e) {
    if (e.key === 'lang' && allProducts.length > 0) renderAll(allProducts, allCategories);
  });

  // ── 语言切换拦截：页面加载且数据就绪后，才拦截 i18n.changeLanguage ──
  // 这样可以确保无论 langChange 事件是否正常工作，页面都能响应语言切换
  if (window.i18n) {
    var originalChangeLanguage = window.i18n.changeLanguage.bind(window.i18n);
    window.i18n.changeLanguage = async function(lang) {
      await originalChangeLanguage(lang);
      // 语言切换完成后，重新渲染产品列表
      if (allProducts.length > 0) renderAll(allProducts, allCategories);
    };
  }

  document.addEventListener('langChange', function() {
    if (allProducts.length > 0) renderAll(allProducts, allCategories);
  });

  // switchCat 全局暴露
  window.switchCat = function(cat) {
    currentCat = cat;
    document.querySelectorAll('.pcat-panel').forEach(el => { el.style.display = 'none'; });
    const target = document.getElementById('panel-' + cat);
    if (target) target.style.display = '';
    document.querySelectorAll('.pcat-tab').forEach(btn => {
      btn.classList.toggle('active', btn.getAttribute('data-cat') === cat);
    });
    // 更新 URL（pushState，不跳页）
    const newPath = '/products/' + cat;
    if (location.pathname !== newPath) history.pushState({ cat }, '', newPath);
    document.getElementById('tabAnchor')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // 处理 URL 切换分类：支持 /products/:catSlug 和旧 hash
  const pathParts = location.pathname.replace(/^\/products\/?/, '').split('/').filter(Boolean);
  const hashSlug = location.hash.replace('#', '');
  const initSlug = pathParts[0] || hashSlug || '';
  if (initSlug) currentCat = initSlug;

  // script 在 body 底部，DOM 已就绪，直接调用；兼容 DOMContentLoaded 已触发的情况
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadAll);
  } else {
    loadAll();
  }
})();
initSEO({ pageTitle: 'Products' });
</script>
</body>
</html>